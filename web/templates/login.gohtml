{{define "login.gohtml"}}
<!doctype html>
<html lang="{{.Locale}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{index .T "auth.login_page_title"}}</title>
  {{template "head-assets" .}}
</head>
<body>
  {{template "site-header-guest" .}}
  <main id="main-content">
    <div class="auth-layout">
      <div class="auth-card">
        <h1>{{index .T "auth.login_title"}}</h1>
        <p class="lead">{{index .T "auth.login_lead"}}</p>
        {{if .Error}}
        <div role="alert" aria-live="assertive" class="form-error" style="margin-bottom:var(--s-3)">
          {{.Error}}
        </div>
        {{end}}
        <form method="post" action="/login" novalidate>
          <div class="form-group">
            <label for="email">{{index .T "auth.email"}}</label>
            <input id="email" name="email" type="email" required
                   autocomplete="email"
                   autofocus
                   spellcheck="false">
          </div>
          <div class="form-group">
            <label for="password">{{index .T "auth.password"}}</label>
            <input id="password" name="password" type="password" required
                   autocomplete="current-password">
          </div>
          <div class="form-actions">
            <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center">
              {{index .T "auth.login_submit"}}
            </button>
          </div>
        </form>
        <p class="auth-switch">{{index .T "auth.no_account_prompt"}} <a href="/signup">{{index .T "auth.signup_submit"}}</a></p>
        <p class="auth-switch"><a href="/forgot-password">{{index .T "auth.forgot_password"}}</a></p>
      </div>
    </div>
  </main>
  {{template "site-footer" .}}
</body>
</html>
{{end}}