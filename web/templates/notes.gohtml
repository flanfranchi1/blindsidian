<!DOCTYPE html>
<html lang="{{.Locale}}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{if .Notebook}}{{.Notebook.Name}} — {{end}}{{index .T "notes.page_title"}}</title>
  {{template "head-assets" .}}
</head>
<body
  data-msg-editing="{{index .T "note.editing_mode"}}"
  data-msg-list-updated="{{index .T "notes.list_updated"}}">
  {{template "site-header" .}}
  {{template "status-region" .}}

  <main id="main-content" class="page-wrapper">
    <h1 class="page-heading">
      {{if .Notebook}}{{.Notebook.Name}}{{else}}{{index .T "notes.heading"}}{{end}}
    </h1>

    <div class="notes-layout">

      <!-- ── Sidebar: notebooks + new notebook ── -->
      <aside class="notes-sidebar" aria-labelledby="notebooks-heading">
        <div class="notebooks-sidebar-wrapper">
          <section class="section-group">
            <h2 id="notebooks-heading">{{index .T "notes.notebooks_heading"}}</h2>
            {{if .Notebooks}}
            <nav aria-label="{{index .T "notes.notebook_list_label"}}">
              <ul class="notebook-list" role="list">
                <li>
                  <a href="/notes"
                     {{if not .Notebook}}aria-current="page"{{end}}>
                    {{index .T "notes.all_notes"}}
                  </a>
                </li>
                {{range .Notebooks}}
                <li>
                  <a href="/notebooks/{{.ID}}"
                     {{if and $.Notebook (eq $.Notebook.ID .ID)}}aria-current="page"{{end}}>
                    {{.Name}}
                  </a>
                </li>
                {{end}}
              </ul>
            </nav>
            {{end}}

            <hr class="divider" style="margin-block:var(--s-4)">

            <section aria-labelledby="new-notebook-heading">
              <h3 id="new-notebook-heading">{{index .T "notes.new_notebook"}}</h3>
              <form method="post" action="/notebooks/create" novalidate>
                <div class="form-group">
                  <label for="notebook-name" class="sr-only">{{index .T "notes.notebook_name_label"}}</label>
                  <input id="notebook-name" name="name" type="text" required
                         placeholder="{{index .T "notes.notebook_name_label"}}"
                         autocomplete="off"
                         aria-describedby="notebook-name-error">
                  <div id="notebook-name-error" class="form-error"
                       role="alert" aria-live="assertive">{{.NotebookNameError}}</div>
                </div>
                <button type="submit" class="btn btn-ghost" style="width:100%;justify-content:center">
                  {{index .T "notes.create_notebook_btn"}}
                </button>
              </form>
            </section>
          </section>
        </div>
      </aside>

      <!-- ── Main content: search · create · list ── -->
      <div class="notes-content">

        <!-- Search (topmost: most frequently used action) -->
        <section class="section-group" aria-labelledby="search-heading">
          <h2 id="search-heading">{{index .T "notes.search_label"}}</h2>
          <div role="search">
            <div class="form-group">
              <label for="global-search">{{index .T "notes.search_label"}}</label>
              <input id="global-search"
                     type="search"
                     name="q"
                     autocomplete="off"
                     spellcheck="false"
                     hx-get="/search"
                     hx-trigger="keyup changed delay:400ms, search"
                     hx-target="#search-results"
                     hx-indicator="#search-indicator"
                     aria-controls="search-results"
                     aria-describedby="search-hint">
              <span id="search-hint" class="sr-only">{{index .T "notes.search_hint"}}</span>
            </div>
            <p class="search-status">
              <span id="search-indicator" class="htmx-indicator" aria-hidden="true">{{index .T "notes.searching"}}</span>
            </p>
          </div>
          <div id="search-results"
               role="region"
               aria-label="{{index .T "notes.search_results_label"}}"
               aria-live="polite"
               aria-atomic="true"></div>
        </section>

        <hr class="divider">

        <!-- Create note -->
        <section class="section-group" aria-labelledby="create-note-heading">
          <h2 id="create-note-heading">{{index .T "notes.new_note"}}</h2>
          <form method="post" action="/notes/create" novalidate>
            <div class="form-group">
              <label for="title">{{index .T "notes.title_label"}}</label>
              <input id="title" name="title" type="text"
                     value="{{.CreateTitle}}" required
                     autocomplete="off"
                     aria-describedby="title-error">
              <div id="title-error" class="form-error"
                   role="alert" aria-live="assertive">{{.TitleError}}</div>
            </div>
            <div class="form-group">
              <label for="notebook-select">{{index .T "notes.notebook_label"}}</label>
              <select id="notebook-select" name="notebook_id">
                <option value="">{{index .T "notes.none"}}</option>
                {{range .Notebooks}}
                <option value="{{.ID}}">{{.Name}}</option>
                {{end}}
              </select>
            </div>
            <div class="form-group">
              <label for="content">
                {{index .T "notes.content_label"}}
                <span class="sr-only">({{index .T "notes.markdown_hint_sr"}})</span>
              </label>
              <textarea id="content" name="content" rows="8" required
                        class="editor-textarea"
                        aria-describedby="content-error content-hint">{{.Content}}</textarea>
              <span id="content-hint" class="form-hint">{{index .T "notes.markdown_hint"}}</span>
              <div id="content-error" class="form-error"
                   role="alert" aria-live="assertive">{{.ContentError}}</div>
            </div>
            <div class="form-actions">
              <button type="submit" class="btn btn-primary">{{index .T "notes.save"}}</button>
            </div>
          </form>
        </section>

        <hr class="divider">

        <!-- Notes list -->
        <section aria-labelledby="notes-list-heading">
          <h2 id="notes-list-heading">{{index .T "notes.all_notes"}}</h2>
          {{if .Notes}}
          <ul class="notes-list" id="notes-list" role="list">
            {{range .Notes}}
            {{template "note_item_fragment" .}}
            {{end}}
          </ul>
          {{else}}
          <p>{{index .T "notes.empty_state"}}</p>
          {{end}}
        </section>

      </div><!-- /.notes-content -->
    </div><!-- /.notes-layout -->
  </main>

  {{template "site-footer" .}}

  <script>
    /* After an HTMX swap: move focus to a meaningful element and
       announce the state change via the ARIA live region. */
    document.body.addEventListener('htmx:afterSwap', function (ev) {
      var statusEl = document.getElementById('system-status');
      setTimeout(function () {
        var textarea = ev.detail.target.querySelector('textarea');
        if (textarea) {
          textarea.focus();
          if (statusEl) statusEl.textContent = document.body.dataset.msgEditing;
          return;
        }
        var heading = ev.detail.target.querySelector('h3, h2');
        if (heading) {
          heading.setAttribute('tabindex', '-1');
          heading.focus();
        }
        if (statusEl) statusEl.textContent = document.body.dataset.msgListUpdated;
      }, 80);
    });
  </script>
</body>
</html>
</body>
</html>