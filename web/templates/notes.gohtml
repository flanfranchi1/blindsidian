<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{if .Notebook}}{{.Notebook.Name}} — {{end}}Notes — notty</title>
  {{template "head-assets" .}}
</head>
<body>
  {{template "site-header" .}}
  {{template "status-region" .}}

  <main id="main-content" class="page-wrapper">
    <h1 class="page-heading">
      {{if .Notebook}}{{.Notebook.Name}}{{else}}Your notes{{end}}
    </h1>

    <div class="notes-layout">

      <!-- ── Sidebar: notebooks ── -->
      <aside class="notes-sidebar" aria-labelledby="notebooks-heading">
        <section class="section-group">
          <h2 id="notebooks-heading">Notebooks</h2>
          {{if .Notebooks}}
          <nav aria-label="Notebook list">
            <ul class="notebook-list" role="list">
              {{range .Notebooks}}
              <li><a href="/notebooks/{{.ID}}">{{.Name}}</a></li>
              {{end}}
            </ul>
          </nav>
          {{end}}

          <hr class="divider">

          <section aria-labelledby="new-notebook-heading">
            <h3 id="new-notebook-heading">New notebook</h3>
            <form method="post" action="/notebooks/create" novalidate>
              <div class="form-group">
                <label for="notebook-name">Notebook name</label>
                <input id="notebook-name" name="name" type="text" required
                       autocomplete="off"
                       aria-describedby="notebook-name-error">
                <div id="notebook-name-error" class="form-error"
                     role="alert" aria-live="assertive">{{.NotebookNameError}}</div>
              </div>
              <button type="submit" class="btn btn-secondary">Create</button>
            </form>
          </section>
        </section>
      </aside>

      <!-- ── Main content: create · search · list ── -->
      <div class="notes-content">

        <!-- Create note -->
        <section class="section-group" aria-labelledby="create-note-heading">
          <h2 id="create-note-heading">New note</h2>
          <form method="post" action="/notes/create" novalidate>
            <div class="form-group">
              <label for="title">Title</label>
              <input id="title" name="title" type="text"
                     value="{{.CreateTitle}}" required
                     autocomplete="off"
                     aria-describedby="title-error">
              <div id="title-error" class="form-error"
                   role="alert" aria-live="assertive">{{.TitleError}}</div>
            </div>
            <div class="form-group">
              <label for="notebook-select">Notebook</label>
              <select id="notebook-select" name="notebook_id">
                <option value="">None</option>
                {{range .Notebooks}}
                <option value="{{.ID}}">{{.Name}}</option>
                {{end}}
              </select>
            </div>
            <div class="form-group">
              <label for="content">Content <span class="sr-only">(Markdown supported)</span></label>
              <textarea id="content" name="content" rows="6" required
                        aria-describedby="content-error content-hint">{{.Content}}</textarea>
              <div id="content-hint" class="sr-only">Markdown is supported. Wiki-links use [[Note Title]] syntax.</div>
              <div id="content-error" class="form-error"
                   role="alert" aria-live="assertive">{{.ContentError}}</div>
            </div>
            <div class="form-actions">
              <button type="submit" class="btn btn-primary">Save note</button>
            </div>
          </form>
        </section>

        <hr class="divider">

        <!-- Search -->
        <section class="section-group" aria-labelledby="search-heading">
          <h2 id="search-heading">Search</h2>
          <div role="search">
            <div class="form-group">
              <label for="global-search">Search all notes</label>
              <input id="global-search"
                     type="search"
                     name="q"
                     autocomplete="off"
                     hx-get="/search"
                     hx-trigger="keyup changed delay:500ms, search"
                     hx-target="#search-results"
                     hx-indicator="#search-indicator"
                     aria-controls="search-results"
                     aria-describedby="search-hint">
              <span id="search-hint" class="sr-only">Results appear below as you type.</span>
            </div>
            <span id="search-indicator" class="htmx-indicator" aria-hidden="true">Searching…</span>
          </div>
          <div id="search-results"
               role="region"
               aria-label="Search results"
               aria-live="polite"
               aria-atomic="true"></div>
        </section>

        <hr class="divider">

        <!-- Notes list -->
        <section aria-labelledby="notes-list-heading">
          <h2 id="notes-list-heading">All notes</h2>
          {{if .Notes}}
          <ul class="notes-list" id="notes-list" role="list">
            {{range .Notes}}
            {{template "note_item_fragment" .}}
            {{end}}
          </ul>
          {{else}}
          <p>No notes yet. Create your first one above.</p>
          {{end}}
        </section>

      </div><!-- /.notes-content -->
    </div><!-- /.notes-layout -->
  </main>

  {{template "site-footer" .}}

  <script>
    /* After an HTMX swap, move focus to the first interactive element
       inside the swapped region and announce the state change. */
    document.body.addEventListener('htmx:afterSwap', function (event) {
      setTimeout(function () {
        var statusEl = document.getElementById('system-status');
        var textarea = event.detail.target.querySelector('textarea');
        if (textarea) {
          textarea.focus();
          if (statusEl) statusEl.textContent = 'Edit mode active.';
        } else {
          var heading = event.detail.target.querySelector('h3');
          if (heading) heading.setAttribute('tabindex', '-1'), heading.focus();
          if (statusEl) statusEl.textContent = 'Note list updated.';
        }
      }, 100);
    });
  </script>
</body>
</html>