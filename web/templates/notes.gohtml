<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <title>Your Notes - Blindsidian</title>
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
</head>
<body>
    <a href="#main-content" class="sr-only">Skip to main content</a>
    <div id="system-messages" role="status" aria-live="polite" class="sr-only"></div>
    
    <header>
        {{if .Notebook}}
        <h1>Notebook: {{.Notebook.Name}}</h1>
        {{else}}
        <h1>Your Notes</h1>
        {{end}}
        <nav aria-label="Main Navigation">
            <ul>
                <li><a href="/logout">Logout</a></li>
            </ul>
        </nav>
    </header>

    <main id="main-content">
        <nav aria-label="Notebooks">
            <h2>Notebooks</h2>
            <ul>
            {{range .Notebooks}}
                <li><a href="/notebooks/{{.ID}}">{{.Name}}</a></li>
            {{end}}
            </ul>
            <section aria-labelledby="create-notebook-heading">
                <h3 id="create-notebook-heading">New Notebook</h3>
                <form method="post" action="/notebooks/create">
                    <div>
                        <label for="notebook-name">Notebook name</label>
                        <input id="notebook-name" name="name" required aria-describedby="notebook-name-error">
                        <div id="notebook-name-error" role="alert" aria-live="assertive">{{.NotebookNameError}}</div>
                    </div>
                    <button type="submit">Create Notebook</button>
                </form>
            </section>
        </nav>

        <section aria-labelledby="create-note-heading">
            <h2 id="create-note-heading">Create a note</h2>
            {{if .Message}}
                <p role="status">{{.Message}}</p>
            {{end}}
            <form method="post" action="/notes/create">
                <div>
                    <label for="title">Title</label>
                    <input id="title" name="title" value="{{.CreateTitle}}" required aria-describedby="title-error">
                    <div id="title-error" role="alert" aria-live="assertive">{{.TitleError}}</div>
                </div>
                <div>
                    <label for="notebook-select">Notebook</label>
                    <select id="notebook-select" name="notebook_id">
                        <option value="">None</option>
                        {{range .Notebooks}}
                        <option value="{{.ID}}">{{.Name}}</option>
                        {{end}}
                    </select>
                </div>
                <div>
                    <label for="content">Note content in Markdown</label>
                    <textarea id="content" name="content" rows="5" required aria-describedby="content-error">{{.Content}}</textarea>
                    <div id="content-error" role="alert" aria-live="assertive">{{.ContentError}}</div>
                </div>
                <button type="submit">Save note</button>
            </form>
        </section>

        <section aria-labelledby="search-heading">
            <h2 id="search-heading">Search notes</h2>
            <div role="search">
                <label for="global-search">Search all notes</label>
                <input id="global-search"
                       type="search"
                       name="q"
                       autocomplete="off"
                       hx-get="/search"
                       hx-trigger="keyup changed delay:500ms, search"
                       hx-target="#search-results"
                       aria-label="Search all notes"
                       aria-controls="search-results"
                       aria-describedby="search-announcer">
            </div>
            <div id="search-announcer" class="sr-only" aria-live="polite" aria-atomic="true"></div>
            <div id="search-results" role="region" aria-label="Search results" aria-live="polite"></div>
        </section>

        <section aria-labelledby="recent-notes-heading">
            <h2 id="recent-notes-heading">Recent notes</h2>
            {{if .Notes}}
                <ul id="notes-list">
                {{range .Notes}}
                    <li id="note-{{.ID}}">
                        <article>
                            <h3><a href="/notes/view?title={{.Title | urlquery}}">{{.Title}}</a></h3>
                            <p>Last update: {{.UpdatedAt}}</p>
                            
                            <button hx-get="/notes/{{.ID}}/edit" 
                                    hx-target="#note-{{.ID}}" 
                                    hx-swap="outerHTML" 
                                    aria-label="Edit note: {{.Title}}">
                                Edit
                            </button>
                            
                            <button hx-post="/notes/{{.ID}}/delete" 
                                    hx-confirm="Are you sure you want to delete this note?" 
                                    hx-target="closest li" 
                                    hx-swap="outerHTML swap:1s"
                                    aria-label="Delete note: {{.Title}}">
                                Delete
                            </button>
                        </article>
                    </li>
                {{end}}
                </ul>
            {{else}}
                <p>No matches found or no notes yet.</p>
            {{end}}
        </section>
    </main>
    <script>
        document.body.addEventListener('htmx:afterSwap', function(event) {
            // O setTimeout de 100ms separa a atualização do DOM do evento de foco.
            // Isso é vital para que o Orca/NVDA não engula o anúncio da região aria-live.
            setTimeout(function() {
                var textarea = document.querySelector('textarea[name="content"]:not(#content)');
                var sysMsg = document.getElementById('system-messages');

                if (textarea) {
                    textarea.focus();
                    if (sysMsg) {
                        sysMsg.innerText = "Edit mode active. Focus is on the markdown content.";
                    }
                } else {
                    if (sysMsg) {
                        sysMsg.innerText = "Note list updated.";
                    }
                }
            }, 100);
        });
    </script>
</body>
</html>