<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{{.Title}} — notty</title>
  {{template "head-assets" .}}
</head>
<body>
  {{template "site-header" .}}
  <div id="system-status" role="status" aria-live="polite" aria-atomic="true" class="sr-only"></div>

  <main id="main-content" class="page-wrapper">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/notes">← All notes</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{{.Title}}</span>
    </nav>

    <div id="note-display-area">
      {{template "note_view_fragment" .}}
    </div>
  </main>

  {{template "site-footer" .}}

  <script>
    /* Refocus after HTMX swaps so keyboard users land in the right place. */
    document.body.addEventListener('htmx:afterSwap', function (ev) {
      if (ev.detail.target.id !== 'note-display-area') return;
      var statusEl = document.getElementById('system-status');
      setTimeout(function () {
        var textarea = document.getElementById('note-content-textarea');
        if (textarea) {
          textarea.focus();
          if (statusEl) statusEl.textContent = 'Editing mode active.';
          return;
        }
        var editBtn = document.getElementById('edit-button');
        if (editBtn) {
          editBtn.focus();
          if (statusEl) statusEl.textContent = 'View mode active.';
        }
      }, 80);
    });
  </script>
</body>
</html>