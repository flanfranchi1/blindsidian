<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Editing: {{.Title}} — notty</title>
  {{template "head-assets" .}}
</head>
<body>
  {{template "site-header" .}}
  <div id="system-status" role="status" aria-live="polite" aria-atomic="true" class="sr-only"></div>

  <main id="main-content" class="page-wrapper">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/notes">← All notes</a>
      <span aria-hidden="true">/</span>
      <span aria-current="page">{{.Title}}</span>
    </nav>

    <form method="post" action="/notes/view/update" aria-labelledby="edit-heading" novalidate>
      <h1 id="edit-heading">Editing: {{.Title}}</h1>

      <input type="hidden" name="original_title" value="{{.Title}}">

      <div class="form-group">
        <label for="edit-title">Title</label>
        <input id="edit-title" name="title" type="text"
               value="{{.Title}}" required
               aria-describedby="edit-title-error">
        <div id="edit-title-error" class="form-error"
             role="alert" aria-live="assertive">{{.TitleError}}</div>
      </div>

      <div class="form-group">
        <label for="edit-notebook-select">Notebook</label>
        <select id="edit-notebook-select" name="notebook_id">
          <option value="">None</option>
          {{range .Notebooks}}
          <option value="{{.ID}}" {{if eq .ID $.NotebookID}}selected{{end}}>{{.Name}}</option>
          {{end}}
        </select>
      </div>

      <div class="form-group">
        <label for="note-content-textarea">
          Content <span class="sr-only">(Markdown supported)</span>
        </label>
        <span id="markdown-hint" class="sr-only">
          Use Markdown syntax. Wiki-links use [[Note Title]] notation.
        </span>
        <textarea id="note-content-textarea"
                  name="content"
                  rows="24"
                  required
                  class="editor-textarea"
                  aria-describedby="markdown-hint edit-content-error">{{.Raw}}</textarea>
        <span class="form-hint" aria-hidden="true">Markdown · link notes with [[Title]]</span>
        <div id="edit-content-error" class="form-error"
             role="alert" aria-live="assertive">{{.ContentError}}</div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn btn-primary">Save changes</button>
        <a href="/notes" class="btn btn-ghost">Cancel</a>
      </div>
    </form>
  </main>

  {{template "site-footer" .}}

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      var textarea = document.getElementById('note-content-textarea');
      if (textarea) textarea.focus();
    });
  </script>
</body>
</html>